"""Generate a Software Bill of Materials (SBOM) for a crosstool-NG built toolchain.

Reads `ct-ng show-config` output (via --show-config FILE or stdin) and the
build log to extract component versions, SHA-512 checksums, and provenance.
Checksums are sourced from the crosstool-NG package tree; the build log is
used as a fallback for packages whose chksum file is not present yet.

The primary download URL of each package (not a mirror) is considered the
canonical provenance source: it is recorded alongside the verified digest,
which makes mirror usage transparent and still auditable.

Outputs SPDX 2.3 JSON or CycloneDX 1.6 JSON.

Usage:
    ct-ng show-config | generate-sbom --format spdx
    generate-sbom --format cyclonedx --show-config show-config.txt
    generate-sbom --format spdx --build-log build.log --output toolchain.spdx.json
"""

import argparse
import json
import re
import sys
import uuid
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path

